\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Bifurcation and stability analysis}{11}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Phase Portrait of the Dual-Bottleneck Dynamics.} The curve shows the evolutionary velocity $\dot  {x}$ using a smoothed simulation model. The system exhibits three equilibria: (1) \textbf  {Trap of Corruption ($x=0$)}: Stable, as review collapse makes spamming profitable. (2) \textbf  {Basin of Honesty ($x=1$)}: Stable, as strict screening deters spamming. (3) \textbf  {Tipping Point ($x^* \approx 0.803$)}: An unstable internal root. Initial states $x > x^*$ recover to honesty, while $x < x^*$ collapse.}}{11}{}\protected@file@percent }
\newlabel{fig:replicator_dynamics}{{3}{11}{}{figure.3}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.1}Analytical Condition for Instability of the Internal Equilibrium}{11}{}\protected@file@percent }
\newlabel{eq:instability_condition}{{48}{12}{}{equation.48}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.5}The regime of stable coexistence: Rationing-dominated dynamics}{12}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Phase Portrait of Stable Coexistence (Rationing-Dominated).} The system exhibits a stable attractor at $x^* \approx 0.49$. \textbf  {Left Zone (Self-Correction):} At low honesty ($x < x^*$), the massive volume of spam triggers severe storage rationing ($\bar  {\rho } \to 0$), reducing the expected payoff of cheating below zero. This forces the population to become more honest. \textbf  {Right Zone (Temptation):} At high honesty ($x > x^*$), the low volume relaxes rationing ($\bar  {\rho } \to 1$), making speculative cheating profitable again due to the base false-positive rate $\lambda $. The system settles into a permanent mix of honest and opportunistic authors.}}{12}{}\protected@file@percent }
\newlabel{fig:stable_coexistence}{{4}{12}{}{figure.4}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.5.1}Mathematical derivation of the stability condition}{12}{}\protected@file@percent }
\newlabel{eq:stable_condition}{{52}{13}{}{equation.52}{}}
