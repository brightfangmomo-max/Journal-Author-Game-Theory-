\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}The Decoupling of Capacities: Phase Diagram Analysis}{15}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.2.1}The Paradox of Slot Expansion}{15}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Phase Diagram of the Dual-Bottleneck System.} The map classifies the topological regime based on the availability of review resources ($K_{rev}$) versus publication slots ($K_{store}$). \textbf  {Green (Global Honesty):} High review capacity ensures cheating is unprofitable ($Q \to 1.0$). \textbf  {Blue (Stable Coexistence):} Extreme slot scarcity ($K_{store} \ll N$) triggers the "Defense by Congestion," stabilizing the system at a mediocre but functional level. \textbf  {Yellow (Bistability):} A transition zone where the outcome is history-dependent. \textbf  {Red (Global Corruption):} When slots are abundant but review is weak, the defense mechanism vanishes, leading to total collapse ($Q \to \alpha $). \textbf  {Gray (System Collapse):} Feasibility constraint violated ($K_{store}$ too low); even honest authors cannot break even.}}{16}{}\protected@file@percent }
\newlabel{fig:regime_map}{{5}{16}{}{figure.5}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.2.2}The Necessity of Review Resources}{16}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Population Pressure and Hysteresis: The Cost of Lost Trust}{16}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Hysteresis Loop and Quality Collapse.} The shaded region represents the bistable interval $[N_{\downarrow }, N_{\uparrow }]$. \textbf  {Left Panel (State):} On the Forward Path (Blue), the "Honest Norm" is resilient ($x_{st} \approx 1$) until the collapse threshold $N_{\uparrow } \approx 1800$. Once corrupted (Red Dashed), the system is trapped in the low-honesty attractor ($x_{st} \approx 0$). Recovery requires reducing $N$ below the distinct recovery threshold $N_{\downarrow } \approx 350$. \textbf  {Right Panel (Quality):} The collapse leads to a discrete jump in quality from $Q=1.0$ to the baseline productivity $Q \approx \alpha \approx 0.2$. This degradation persists even if $N$ is reduced moderately, illustrating the "Quality Trap."}}{17}{}\protected@file@percent }
\newlabel{fig:hysteresis}{{6}{17}{}{figure.6}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.1}Structural Resilience (Forward Path)}{17}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.2}The Stickiness of Corruption (Backward Path)}{17}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.3}Policy Implication: Basin Hopping}{18}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {5}Joint Impact of Population and Capacity on Publication Quality}{18}{}\protected@file@percent }
\newlabel{fig:nk_stability}{{7a}{19}{}{subfigure.7.1}{}}
\newlabel{sub@fig:nk_stability}{{a}{19}{}{subfigure.7.1}{}}
\newlabel{fig:nk_quality}{{7b}{19}{}{subfigure.7.2}{}}
\newlabel{sub@fig:nk_quality}{{b}{19}{}{subfigure.7.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Joint analysis of system stability and publication quality under varying Population ($N$) and Capacity ($K$). (a) The stability landscape shows the transition from Global Honesty (Green/Blue) to Global Corruption (Red) via a Bistable region. (b) The quality landscape reveals a sharp \textbf  {Phase Transition}. The quality remains at a perfect $1.0$ (Green) until the critical threshold is crossed, causing an instantaneous drop to a low plateau of $\approx 0.4$ (Red), signifying the catastrophic collapse of the peer-review filter due to congestion.}}{19}{}\protected@file@percent }
\newlabel{fig:joint_NK_analysis}{{7}{19}{}{figure.7}{}}
